{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/codex-review-output.schema.json",
  "title": "Codex Independent Review Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewer",
    "contract_result",
    "policy_result",
    "risk_result",
    "findings",
    "recommendation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "reviewer": {
      "type": "string"
    },
    "contract_result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "policy_result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "risk_result": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "proceed",
        "revise",
        "block"
      ]
    }
  }
}
