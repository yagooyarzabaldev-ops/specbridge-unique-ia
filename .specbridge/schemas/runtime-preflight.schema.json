{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/runtime-preflight.schema.json",
  "title": "SpecBridge Runtime Preflight",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "command",
    "ok",
    "mode",
    "input_paths",
    "loaded_launches",
    "required_slices",
    "present_slices",
    "missing_required_slices",
    "duplicate_slices",
    "non_overlap",
    "budget",
    "tools",
    "execution_policy",
    "blockers",
    "policy_boundary",
    "source_files",
    "output_path"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "ok": { "type": "boolean" },
    "mode": { "type": "string" },
    "input_paths": { "type": "array", "items": { "type": "string" } },
    "loaded_launches": { "type": "array", "items": { "type": "object" } },
    "required_slices": { "type": "array", "items": { "type": "string" } },
    "present_slices": { "type": "array", "items": { "type": "string" } },
    "missing_required_slices": { "type": "array", "items": { "type": "string" } },
    "duplicate_slices": { "type": "array", "items": { "type": "string" } },
    "non_overlap": { "type": "object" },
    "budget": { "type": "object" },
    "tools": { "type": "object" },
    "execution_policy": { "type": "object" },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "policy_boundary": { "type": "string" },
    "source_files": { "type": "array", "items": { "type": "string" } },
    "output_path": { "type": "string" }
  }
}
