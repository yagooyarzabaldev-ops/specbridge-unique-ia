{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/runtime-execution.schema.json",
  "title": "SpecBridge Runtime Execution",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "execution_id",
    "generated_by",
    "runtime_launch_path",
    "launch_id",
    "task_id",
    "packet_id",
    "slice_id",
    "branch_name",
    "dry_run",
    "timeout_seconds",
    "allowed_tools",
    "permission_mode",
    "max_budget_usd",
    "command_summary",
    "prompt_sections",
    "execution_status",
    "exit_code",
    "timed_out",
    "stdout",
    "stderr",
    "policy_result",
    "execution_policy",
    "source_files"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "execution_id": { "type": "string" },
    "generated_by": { "type": "string" },
    "runtime_launch_path": { "type": "string" },
    "launch_id": { "type": "string" },
    "task_id": { "type": "string" },
    "packet_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "branch_name": { "type": "string" },
    "dry_run": { "type": "boolean" },
    "timeout_seconds": { "type": "integer" },
    "allowed_tools": { "type": "array", "items": { "type": "string" } },
    "permission_mode": { "type": "string" },
    "max_budget_usd": { "type": "string" },
    "command_summary": { "type": "string" },
    "prompt_sections": { "type": "array", "items": { "type": "string" } },
    "execution_status": { "type": "string" },
    "exit_code": { "type": ["integer", "null"] },
    "timed_out": { "type": "boolean" },
    "stdout": { "type": "object" },
    "stderr": { "type": "object" },
    "policy_result": { "type": "string" },
    "execution_policy": { "type": "object" },
    "source_files": { "type": "array", "items": { "type": "string" } }
  }
}
