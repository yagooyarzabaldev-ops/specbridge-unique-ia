{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/autonomy-metrics.schema.json",
  "title": "SpecBridge Autonomy Metrics",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "metrics_id",
    "generated_by",
    "summary_count",
    "ready_count",
    "blocked_count",
    "executor_count",
    "validation_totals",
    "runtime_status_counts",
    "result_status_counts",
    "completion_status_counts",
    "merge_readiness_counts",
    "policy_gate_ready_rate",
    "source_summaries",
    "source_results",
    "source_files"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "metrics_id": { "type": "string" },
    "generated_by": { "type": "string" },
    "task_filter": { "type": ["string", "null"] },
    "summary_count": { "type": "integer" },
    "ready_count": { "type": "integer" },
    "blocked_count": { "type": "integer" },
    "executor_count": { "type": "integer" },
    "validation_totals": { "type": "object" },
    "runtime_status_counts": { "type": "object" },
    "result_status_counts": { "type": "object" },
    "completion_status_counts": { "type": "object" },
    "merge_readiness_counts": { "type": "object" },
    "policy_gate_ready_rate": { "type": "number" },
    "source_summaries": { "type": "array", "items": { "type": "string" } },
    "source_results": { "type": "array", "items": { "type": "string" } },
    "source_files": { "type": "array", "items": { "type": "string" } }
  }
}
