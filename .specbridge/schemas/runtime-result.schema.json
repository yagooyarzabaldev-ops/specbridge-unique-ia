{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/runtime-result.schema.json",
  "title": "SpecBridge Runtime Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "result_id",
    "source_runtime_launch_path",
    "launch_id",
    "task_id",
    "packet_id",
    "slice_id",
    "branch_name",
    "executor_evidence_path",
    "exit_code",
    "files_written",
    "validation_results",
    "policy_result",
    "completion_status",
    "runtime_status",
    "result_status",
    "execution_policy",
    "source_files"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "result_id": { "type": "string" },
    "source_runtime_launch_path": { "type": "string" },
    "launch_id": { "type": "string" },
    "task_id": { "type": "string" },
    "packet_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "branch_name": { "type": "string" },
    "executor_evidence_path": { "type": "string" },
    "exit_code": { "type": "integer" },
    "files_written": { "type": "array", "items": { "type": "string" } },
    "validation_results": { "type": "array", "items": { "type": "object" } },
    "policy_result": { "type": "string" },
    "completion_status": { "type": "string" },
    "runtime_status": { "type": "string" },
    "result_status": { "type": "string" },
    "execution_policy": { "type": "object" },
    "source_files": { "type": "array", "items": { "type": "string" } }
  }
}
