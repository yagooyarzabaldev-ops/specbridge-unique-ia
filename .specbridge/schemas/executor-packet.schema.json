{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/executor-packet.schema.json",
  "title": "SpecBridge Executor Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "packet_id",
    "task_id",
    "slice_id",
    "branch_name",
    "execution_contract_path",
    "final_report_path",
    "exclusive_write",
    "read_only",
    "required_validations",
    "stop_conditions",
    "status",
    "source_files"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "packet_id": { "type": "string" },
    "task_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "branch_name": { "type": "string" },
    "execution_contract_path": { "type": "string" },
    "final_report_path": { "type": "string" },
    "exclusive_write": { "type": "array", "items": { "type": "string" } },
    "read_only": { "type": "array", "items": { "type": "string" } },
    "required_validations": { "type": "array", "items": { "type": "string" } },
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string" },
    "source_files": { "type": "array", "items": { "type": "string" } }
  }
}
