{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/runtime-summary.schema.json",
  "title": "SpecBridge Runtime Summary",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "summary_id",
    "runtime_launch_path",
    "runtime_result_path",
    "launch_id",
    "task_id",
    "packet_id",
    "slice_id",
    "branch_name",
    "completion_status",
    "runtime_status",
    "result_status",
    "validation_totals",
    "policy_result",
    "merge_readiness",
    "blockers",
    "execution_policy",
    "source_files"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "summary_id": { "type": "string" },
    "runtime_launch_path": { "type": "string" },
    "runtime_result_path": { "type": "string" },
    "launch_id": { "type": "string" },
    "task_id": { "type": "string" },
    "packet_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "branch_name": { "type": "string" },
    "completion_status": { "type": "string" },
    "runtime_status": { "type": "string" },
    "result_status": { "type": "string" },
    "validation_totals": { "type": "object" },
    "policy_result": { "type": "string" },
    "merge_readiness": { "type": "string" },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "execution_policy": { "type": "object" },
    "source_files": { "type": "array", "items": { "type": "string" } }
  }
}
