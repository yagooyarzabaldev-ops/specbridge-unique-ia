{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/runtime-launch.schema.json",
  "title": "SpecBridge Runtime Launch",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "launch_id",
    "source_executor_packet_path",
    "task_id",
    "packet_id",
    "slice_id",
    "branch_name",
    "execution_contract_path",
    "final_report_path",
    "exclusive_write",
    "read_only",
    "required_validations",
    "allowed_tools",
    "permission_mode",
    "max_budget_usd",
    "command_summary",
    "prompt_sections",
    "stop_conditions",
    "launch_status",
    "execution_policy",
    "source_files"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "launch_id": { "type": "string" },
    "source_executor_packet_path": { "type": "string" },
    "task_id": { "type": "string" },
    "packet_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "branch_name": { "type": "string" },
    "execution_contract_path": { "type": "string" },
    "final_report_path": { "type": "string" },
    "exclusive_write": { "type": "array", "items": { "type": "string" } },
    "read_only": { "type": "array", "items": { "type": "string" } },
    "required_validations": { "type": "array", "items": { "type": "string" } },
    "allowed_tools": { "type": "array", "items": { "type": "string" } },
    "permission_mode": { "type": "string" },
    "max_budget_usd": { "type": "string" },
    "max_turns": { "type": "integer" },
    "conditional_flags": { "type": "object" },
    "command_summary": { "type": "string" },
    "prompt_sections": { "type": "array", "items": { "type": "string" } },
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "launch_status": { "type": "string" },
    "execution_policy": { "type": "object" },
    "source_files": { "type": "array", "items": { "type": "string" } }
  }
}
