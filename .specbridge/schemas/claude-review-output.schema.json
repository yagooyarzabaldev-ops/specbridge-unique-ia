{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specbridge.local/schemas/claude-review-output.schema.json",
  "title": "Claude Review Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewer",
    "summary",
    "findings",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "reviewer": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "needs_human_review"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "category",
          "file",
          "evidence",
          "recommendation",
          "blocking"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "category": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "evidence": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
